<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>DANFE — NF-e nº {{ nfe.number }}</title>
    <style>
        @page { size: A4 portrait; margin: 7mm; }
        * { box-sizing: border-box; }
        body { margin: 0; font-family: DejaVu Sans, sans-serif; font-size: 8px; color: #000; }
        table { width: 100%; border-collapse: collapse; }
        td, th { border: 1px solid #000; padding: 1px 3px; vertical-align: top; }
        .nb  { border: none !important; }
        .lbl { display: block; font-size: 6px; text-transform: uppercase; color: #444; }
        .val { display: block; font-size: 8px; font-weight: bold; line-height: 1.3; }
        .sec { background: #d0d0d0; text-align: center; font-size: 8px; font-weight: bold; text-transform: uppercase; padding: 2px; }
        .center { text-align: center; }
        .right  { text-align: right; }
        .homolog-notice {
            border: 2px solid #000; padding: 3px; text-align: center;
            font-weight: bold; font-size: 10px; margin-bottom: 3px;
        }
        /* canhoto */
        .canhoto { border: 1px solid #000; margin-bottom: 4px; }
        .canhoto td { border: none; }
        .canhoto .divider-left { border-left: 1px dashed #000 !important; }
        .canhoto .sig-line   { border-top: 1px solid #000 !important; padding-top: 2px; font-size: 6px; text-transform: uppercase; }
        /* header */
        .danfe-title    { font-size: 18px; font-weight: bold; text-align: center; line-height: 1; }
        .danfe-subtitle { font-size: 7px; text-align: center; line-height: 1.4; }
        .emit-name      { font-size: 10px; font-weight: bold; text-align: center; }
        .emit-addr      { font-size: 7.5px; text-align: center; }
        /* access key */
        .key-lbl  { font-size: 6px; text-transform: uppercase; text-align: center; display: block; margin-bottom: 1px; }
        .key-val  { font-size: 7.5px; font-weight: bold; text-align: center; letter-spacing: 0.3px; margin-bottom: 2px; }
        .key-note { font-size: 6px; text-align: center; color: #444; }
        .barcode-img { text-align: center; }
        .barcode-img img { max-width: 100%; height: 36px; }
        /* items */
        .items-hdr th { background: #efefef; font-size: 6.5px; text-align: center; padding: 1px; }
        .items-hdr td { font-size: 6.5px; padding: 1px 2px; }
        {% block extra_styles %}{% endblock %}
    </style>
</head>
<body>

{% set accessKey = accessKey|default('') %}
{% set details   = nfe.details() %}
{% set totals    = details['totals'] ?? {} %}
{% set ide       = details['ide']    ?? {} %}
{% set transp    = details['transport'] ?? {} %}
{% set nfNumStr  = '%09d'|format(nfe.number|default(0)) %}
{% set nfNum     = nfNumStr|slice(0,3) ~ '.' ~ nfNumStr|slice(3,3) ~ '.' ~ nfNumStr|slice(6,3) %}
{% set serieStr  = '%03d'|format(nfe.series|default(0)) %}

{% if document.environment == '2' or document.environment == 'homolog' %}
    <div class="homolog-notice">EMITIDA EM AMBIENTE DE HOMOLOGAÇÃO — SEM VALOR FISCAL</div>
{% endif %}

{# ═══ CANHOTO ══════════════════════════════════════════════════════════════════ #}
<table class="canhoto" style="margin-bottom: 4px;">
    <tr>
        <td style="width: 68%; padding: 3px 4px; border-right: 1px dashed #000;">
            <div style="font-size: 7px; font-weight: bold; text-transform: uppercase; margin-bottom: 3px;">
                Recebemos de <strong>{{ nfe.emit_name }}</strong> os produtos e/ou serviços constantes
                da Nota Fiscal Eletrônica indicada abaixo.
                Emissão: {{ nfe.issued_at|date('d/m/Y') }} &nbsp;
                Valor Total: R$&nbsp;{{ (totals['invoice_value']|default(nfe.total_value|default(0)))|number_format(2,',','.') }}
                &nbsp; Destinatário: {{ nfe.dest_name }} — {{ nfe.dest_address_street }},
                {{ nfe.dest_address_number }} {{ nfe.dest_address_city }}/{{ nfe.dest_address_state }}
            </div>
            <table style="border: none;">
                <tr>
                    <td class="sig-line" style="width: 30%; border: none; border-top: 1px solid #000;">Data de recebimento</td>
                    <td class="sig-line" style="border: none; border-top: 1px solid #000;">Identificação e Assinatura do Recebedor</td>
                </tr>
            </table>
        </td>
        <td style="width: 32%; text-align: center; padding: 3px 5px; vertical-align: middle;">
            <div style="font-size: 8px; font-weight: bold;">NF-e</div>
            <div style="font-size: 13px; font-weight: bold;">Nº. {{ nfNum }}</div>
            <div style="font-size: 8px;">Série {{ serieStr }}</div>
            <table style="border: none; margin-top: 4px;">
                <tr>
                    <td class="sig-line" style="border: none; border-top: 1px solid #000; width: 50%; font-size: 6px; text-transform: uppercase; padding-top: 2px;">Data de recebimento</td>
                    <td class="sig-line" style="border: none; border-top: 1px solid #000; font-size: 6px; text-transform: uppercase; padding-top: 2px;">Assinatura</td>
                </tr>
            </table>
        </td>
    </tr>
</table>

{# ═══ CABEÇALHO PRINCIPAL ══════════════════════════════════════════════════════ #}
<table style="margin-bottom: 2px;">
    <tr>
        {# Coluna esquerda: emitente #}
        <td style="width: 35%; text-align: center; padding: 4px 6px;">
            <div style="font-size: 6.5px; text-transform: uppercase; color: #555; margin-bottom: 2px; font-style: italic;">Identificação do emitente</div>
            {% block logo %}{% endblock %}
            <div class="emit-name">{{ nfe.emit_name }}</div>
            <div class="emit-addr">
                {{ nfe.emit_address_street }}, {{ nfe.emit_address_number }}
                {% if nfe.emit_address_complement %} – {{ nfe.emit_address_complement }}{% endif %}
            </div>
            <div class="emit-addr">
                {{ nfe.emit_address_neighborhood }} — {{ nfe.emit_address_zipcode|default('') }}
            </div>
            <div class="emit-addr">
                {{ nfe.emit_address_city }}/{{ nfe.emit_address_state }}
                {% if nfe.emit_phone %} &nbsp; Fone: {{ nfe.emit_phone }}{% endif %}
            </div>
        </td>

        {# Coluna central: DANFE / número #}
        <td style="width: 28%; text-align: center; padding: 4px;">
            <div class="danfe-title">DANFE</div>
            <div class="danfe-subtitle">Documento Auxiliar da<br>Nota Fiscal Eletrônica</div>
            <div style="margin: 4px auto; width: 60px; border: 1px solid #000; padding: 2px; text-align: center;">
                <div style="font-size: 6px; text-transform: uppercase;">0 – Entrada</div>
                <div style="font-size: 6px; text-transform: uppercase;">1 – Saída</div>
                <div style="font-size: 18px; font-weight: bold; line-height: 1;">
                    {{ (ide['tp_nf']|default('1')) == '1' ? '1' : '0' }}
                </div>
            </div>
            <div style="font-size: 7px; text-transform: uppercase; margin-top: 2px;">Nº. {{ nfNum }}</div>
            <div style="font-size: 7px; text-transform: uppercase;">Série {{ serieStr }}</div>
            <div style="font-size: 7px; margin-top: 2px;">Folha 1/1</div>
        </td>

        {# Coluna direita: barcode + chave de acesso #}
        <td style="width: 37%; text-align: center; padding: 3px 4px;">
            {% if accessKeyBarcode is defined and accessKeyBarcode %}
            <div class="barcode-img" style="margin-bottom: 2px;">
                <img src="data:image/png;base64,{{ accessKeyBarcode }}" alt="Código de barras">
            </div>
            {% endif %}
            <span class="key-lbl">Chave de Acesso</span>
            {% if accessKey %}
            <div class="key-val">
                {% set k = accessKey %}
                {{ k|slice(0,4) }} {{ k|slice(4,4) }} {{ k|slice(8,4) }} {{ k|slice(12,4) }}
                {{ k|slice(16,4) }} {{ k|slice(20,4) }} {{ k|slice(24,4) }} {{ k|slice(28,4) }}
                {{ k|slice(32,4) }} {{ k|slice(36,4) }} {{ k|slice(40,4) }}
            </div>
            {% endif %}
            <div class="key-note">
                Consulta de autenticidade no portal nacional da NF-e<br>
                www.nfe.fazenda.gov.br/portal ou no site da Sefaz Autorizadora
            </div>
        </td>
    </tr>
</table>

{# ── Natureza da Operação / Protocolo ──────────────────────────────────────── #}
<table style="margin-bottom: 2px;">
    <tr>
        <td style="width: 55%;">
            <span class="lbl">Natureza da Operação</span>
            <span class="val">{{ ide['nat_op']|default('-') }}</span>
        </td>
        <td style="width: 45%;">
            <span class="lbl">Protocolo de Autorização de Uso</span>
            <span class="val">{{ document.authorization_protocol|default(ide['auth_protocol']|default('-')) }}</span>
        </td>
    </tr>
</table>

{# ── CNPJ / IE do emitente ─────────────────────────────────────────────────── #}
<table style="margin-bottom: 2px;">
    <tr>
        <td style="width: 25%;">
            <span class="lbl">Inscrição Estadual</span>
            <span class="val">{{ nfe.emit_state_registration|default('-') }}</span>
        </td>
        <td style="width: 25%;">
            <span class="lbl">Inscrição Municipal</span>
            <span class="val">{{ nfe.emit_city_registration|default('-') }}</span>
        </td>
        <td style="width: 25%;">
            <span class="lbl">Insc. Estadual Subst. Trib.</span>
            <span class="val">—</span>
        </td>
        <td style="width: 25%;">
            <span class="lbl">CNPJ / CPF</span>
            <span class="val">{{ nfe.emit_document|default('-') }}</span>
        </td>
    </tr>
</table>

{# ═══ DESTINATÁRIO / REMETENTE ═════════════════════════════════════════════════ #}
<table style="margin-bottom: 2px;">
    <tr>
        <td colspan="3" class="sec">Destinatário / Remetente</td>
    </tr>
    <tr>
        <td style="width: 50%;">
            <span class="lbl">Nome / Razão Social</span>
            <span class="val">{{ nfe.dest_name|default('-') }}</span>
        </td>
        <td style="width: 25%;">
            <span class="lbl">CNPJ / CPF</span>
            <span class="val">{{ nfe.dest_document|default('-') }}</span>
        </td>
        <td style="width: 25%;">
            <span class="lbl">Data da Emissão</span>
            <span class="val">{{ nfe.issued_at|date('d/m/Y') }}</span>
        </td>
    </tr>
    <tr>
        <td colspan="2">
            <span class="lbl">Endereço</span>
            <span class="val">
                {{ nfe.dest_address_street|default('') }}, {{ nfe.dest_address_number|default('') }}
                {% if nfe.dest_address_complement|default('') %} – {{ nfe.dest_address_complement }}{% endif %}
            </span>
        </td>
        <td>
            <span class="lbl">CEP</span>
            <span class="val">{{ nfe.dest_address_zipcode|default('-') }}</span>
        </td>
    </tr>
    <tr>
        <td style="width: 35%;">
            <span class="lbl">Bairro / Distrito</span>
            <span class="val">{{ nfe.dest_address_neighborhood|default('-') }}</span>
        </td>
        <td style="width: 30%;">
            <span class="lbl">Município</span>
            <span class="val">{{ nfe.dest_address_city|default('-') }}</span>
        </td>
        <td style="width: 15%;">
            <span class="lbl">UF</span>
            <span class="val">{{ nfe.dest_address_state|default('-') }}</span>
        </td>
    </tr>
</table>

{# ═══ CÁLCULO DO IMPOSTO / TOTAIS ══════════════════════════════════════════════ #}
<table style="margin-bottom: 2px;">
    <tr>
        <td colspan="8" class="sec">Cálculo do Imposto</td>
    </tr>
    <tr>
        <td style="width: 13%;">
            <span class="lbl">Base de Cálc. do ICMS</span>
            <span class="val">{{ (totals['icms_base']|default(0))|number_format(2,',','.') }}</span>
        </td>
        <td style="width: 12%;">
            <span class="lbl">Valor do ICMS</span>
            <span class="val">{{ (totals['icms_value']|default(0))|number_format(2,',','.') }}</span>
        </td>
        <td style="width: 13%;">
            <span class="lbl">Base de Cálc. ICMS S.T.</span>
            <span class="val">{{ (totals['icms_st_base']|default(0))|number_format(2,',','.') }}</span>
        </td>
        <td style="width: 13%;">
            <span class="lbl">Valor ICMS Subst.</span>
            <span class="val">{{ (totals['icms_st_value']|default(0))|number_format(2,',','.') }}</span>
        </td>
        <td style="width: 12%;">
            <span class="lbl">Valor IPI</span>
            <span class="val">{{ (totals['ipi_value']|default(0))|number_format(2,',','.') }}</span>
        </td>
        <td style="width: 12%;">
            <span class="lbl">Valor Total Produtos</span>
            <span class="val">{{ (totals['products_value']|default(nfe.total_value|default(0)))|number_format(2,',','.') }}</span>
        </td>
        <td style="width: 12%; background: #efefef;">
            <span class="lbl">Valor Total NF-e</span>
            <span class="val" style="font-size: 10px;">{{ (totals['invoice_value']|default(nfe.total_value|default(0)))|number_format(2,',','.') }}</span>
        </td>
    </tr>
    <tr>
        <td>
            <span class="lbl">Valor do Frete</span>
            <span class="val">{{ (totals['freight_value']|default(nfe.freight_value|default(0)))|number_format(2,',','.') }}</span>
        </td>
        <td>
            <span class="lbl">Valor do Seguro</span>
            <span class="val">{{ (totals['insurance_value']|default(0))|number_format(2,',','.') }}</span>
        </td>
        <td>
            <span class="lbl">Desconto</span>
            <span class="val">{{ (totals['discount_value']|default(0))|number_format(2,',','.') }}</span>
        </td>
        <td>
            <span class="lbl">Outras Despesas</span>
            <span class="val">{{ (totals['other_value']|default(0))|number_format(2,',','.') }}</span>
        </td>
        <td>
            <span class="lbl">V. Tot. Tributos</span>
            <span class="val">{{ (totals['total_tributes']|default(0))|number_format(2,',','.') }}</span>
        </td>
        <td colspan="2">
            &nbsp;
        </td>
    </tr>
</table>

{# ═══ TRANSPORTADOR / VOLUMES ══════════════════════════════════════════════════ #}
<table style="margin-bottom: 2px;">
    <tr>
        <td colspan="6" class="sec">Transportador / Volumes Transportados</td>
    </tr>
    <tr>
        <td style="width: 35%;">
            <span class="lbl">Razão Social</span>
            <span class="val">{{ nfe.transp_name|default('-') }}</span>
        </td>
        <td style="width: 20%;">
            <span class="lbl">Modalidade do Frete</span>
            <span class="val">
                {% set fm = nfe.freight_mode|default('9') %}
                {% if fm == '0' %}0 – Emitente
                {% elseif fm == '1' %}1 – Destinatário
                {% elseif fm == '2' %}2 – Terceiros
                {% elseif fm == '9' %}9 – Sem frete
                {% else %}{{ fm }}{% endif %}
            </span>
        </td>
        <td style="width: 20%;">
            <span class="lbl">CNPJ / CPF</span>
            <span class="val">{{ nfe.transp_document|default('-') }}</span>
        </td>
        <td style="width: 10%; text-align: center;">
            <span class="lbl">Quantidade</span>
            <span class="val">{{ nfe.package_count|default(0) }}</span>
        </td>
        <td style="width: 8%; text-align: center;">
            <span class="lbl">Espécie</span>
            <span class="val">{{ transp['package_type']|default('-') }}</span>
        </td>
        <td style="width: 12%; text-align: right;">
            <span class="lbl">Peso Bruto</span>
            <span class="val">{{ (nfe.total_weight_grams|default(0) / 1000)|number_format(3,',','.') }} kg</span>
        </td>
    </tr>
</table>

{# ═══ DADOS DOS PRODUTOS / SERVIÇOS ════════════════════════════════════════════ #}
<table class="items-hdr" style="margin-bottom: 2px;">
    <tr>
        <td colspan="9" class="sec">Dados dos Produtos / Serviços</td>
    </tr>
    <tr>
        <th style="width: 8%;">Código</th>
        <th style="width: 35%;">Descrição do Produto / Serviço</th>
        <th style="width: 8%;">NCM/SH</th>
        <th style="width: 6%;">CFOP</th>
        <th style="width: 5%;">UN</th>
        <th style="width: 8%; text-align: right;">Quant.</th>
        <th style="width: 10%; text-align: right;">Valor Unit.</th>
        <th style="width: 10%; text-align: right;">Valor Total</th>
        <th style="width: 10%; text-align: right;">Desc.</th>
    </tr>
    {% if items is empty %}
        <tr>
            <td colspan="9" class="center" style="font-style: italic; padding: 4px;">Sem itens detalhados</td>
        </tr>
    {% else %}
        {% for item in items %}
        <tr>
            <td>{{ item.code|default('-') }}</td>
            <td>{{ item.description|default('-') }}</td>
            <td class="center">{{ item.ncm|default('-') }}</td>
            <td class="center">{{ item.cfop|default('-') }}</td>
            <td class="center">{{ item.unit|default('-') }}</td>
            <td class="right">{{ item.quantity|default(0)|number_format(4,',','.') }}</td>
            <td class="right">{{ item.unit_value|default(0)|number_format(2,',','.') }}</td>
            <td class="right">{{ item.total_value|default(0)|number_format(2,',','.') }}</td>
            <td class="right">{{ item.discount_value|default(0)|number_format(2,',','.') }}</td>
        </tr>
        {% endfor %}
    {% endif %}
</table>

{# ═══ DADOS ADICIONAIS ═════════════════════════════════════════════════════════ #}
{% block additional_info %}
<table style="margin-bottom: 2px;">
    <tr>
        <td colspan="2" class="sec">Dados Adicionais</td>
    </tr>
    <tr>
        <td style="width: 75%;">
            <span class="lbl">Informações Complementares</span>
            <div style="font-size: 7.5px; line-height: 1.3; min-height: 20px;">
                {{ nfe.additional_info|default('') }}
            </div>
        </td>
        <td style="width: 25%;">
            <span class="lbl">Reservado ao Fisco</span>
            <div style="min-height: 20px;"></div>
        </td>
    </tr>
</table>
{% endblock %}

{% block footer %}{% endblock %}

</body>
</html>
