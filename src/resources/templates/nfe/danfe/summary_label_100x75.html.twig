<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>DANFE Resumida 100x75</title>
    <style>
        @page { size: 100mm 75mm; margin: 1.8mm; }
        * { box-sizing: border-box; }
        html, body { margin: 0; padding: 0; }
        body { font-family: DejaVu Sans, sans-serif; font-size: 6.3px; color: #000; line-height: 1.02; }

        .page { width: 100%; border: 1px solid #000; padding: 2px 3px; page-break-inside: avoid; }

        .notice { text-align: center; font-weight: bold; font-size: 6.4px; margin-bottom: 1px; line-height: 1.05; }
        .title  { text-align: center; font-weight: bold; font-size: 7.1px; line-height: 1.05; margin-bottom: 1px; text-transform: uppercase; }

        .center-line  { text-align: center; margin-bottom: 0.5px; line-height: 1.03; }
        .label { font-weight: bold; text-transform: uppercase; }

        .section       { margin-top: 2px; text-align: center; }
        .section .line { margin-bottom: 0.4px; line-height: 1.03; }

        .value-box { margin-top: 2px; border: 1px solid #000; padding: 1px 2px; text-align: center; }
        .value-label  { font-size: 5.5px; text-transform: uppercase; font-weight: bold; display: block; }
        .value-amount { font-size: 9px; font-weight: bold; display: block; margin-top: 0.5px; }

        .access-key-title { margin-top: 2px; text-align: center; font-weight: bold; font-size: 6.6px; line-height: 1.03; }
        .access-key-value { text-align: center; font-weight: bold; font-size: 6.2px; line-height: 1.08; word-spacing: 0.5px; margin-top: 0.5px; }

        {% block extra_styles %}{% endblock %}
    </style>
</head>
<body>
<div class="page">

    {% if document.environment == '2' or document.environment == 'homolog' %}
        <div class="notice">EMITIDA EM HOMOLOGAÇÃO — SEM VALOR FISCAL</div>
    {% endif %}

    {% block logo %}{% endblock %}

    <div class="title">DANFE SIMPLIFICADA — NOTA FISCAL ELETRÔNICA</div>

    <div class="center-line">Nº {{ nfe.number }} SÉRIE {{ nfe.series }}</div>
    <div class="center-line"><span class="label">DATA DE EMISSÃO:</span> {{ nfe.issued_at|date('d/m/Y H:i') }}</div>

    <div class="section">
        <div class="line"><span class="label">CNPJ EMITENTE:</span> {{ nfe.emit_document ?: '-' }}</div>
        <div class="line"><span class="label">NOME EMITENTE:</span> {{ nfe.emit_name ?: '-' }}</div>
        <div class="line">
            {{ nfe.emit_address_city ?: '-' }}/{{ nfe.emit_address_state ?: '' }}
        </div>
    </div>

    <div class="section">
        <div class="line"><span class="label">CNPJ/CPF DESTINATÁRIO:</span> {{ nfe.dest_document ?: '-' }}</div>
        <div class="line"><span class="label">NOME DESTINATÁRIO:</span> {{ nfe.dest_name ?: '-' }}</div>
        <div class="line">
            {{ nfe.dest_address_street ?: '-' }}, {{ nfe.dest_address_number ?: '' }}
            — {{ nfe.dest_address_city ?: '' }}/{{ nfe.dest_address_state ?: '' }}
        </div>
        <div class="line"><span class="label">CEP:</span> {{ nfe.dest_address_zipcode ?: '-' }}</div>
    </div>

    <div class="value-box">
        <span class="value-label">Valor Total NF-e</span>
        <span class="value-amount">R$ {{ nfe.total_value|default(0)|number_format(2, ',', '.') }}</span>
    </div>

    <div class="access-key-title">Chave de Acesso NF-e</div>
    <div class="access-key-value">
        {% set k = accessKey|default('') %}
        {% if k %}
            {{ k|slice(0,4) }} {{ k|slice(4,4) }} {{ k|slice(8,4) }} {{ k|slice(12,4) }} {{ k|slice(16,4) }}
            {{ k|slice(20,4) }} {{ k|slice(24,4) }} {{ k|slice(28,4) }} {{ k|slice(32,4) }} {{ k|slice(36,4) }}
            {{ k|slice(40,4) }}
        {% else %}-{% endif %}
    </div>

    {% block footer %}{% endblock %}
</div>
</body>
</html>
