{#
  DACE resumida — fragmento para embutir em relatório A4.
  Sem <html>/<head>/<body>: o papel é controlado pelo template pai.
#}

<style>
    .dace-a4-page { width: 198mm; min-height: 120mm; margin: 5mm 0 0 0; border: 1px solid #000; padding: 7mm 8mm 8mm 8mm; box-sizing: border-box; font-family: DejaVu Sans, Arial, sans-serif; font-size: 11.5px; color: #000; line-height: 1.18; page-break-inside: avoid; text-align: left; }
    .dace-a4-page * { box-sizing: border-box; }
    .dace-a4-page .notice { text-align: center; font-weight: bold; font-size: 12px; margin-bottom: 2px; }
    .dace-a4-page .title  { text-align: center; font-weight: bold; font-size: 17px; line-height: 1.12; margin-bottom: 5px; text-transform: uppercase; }
    .dace-a4-page .center-line { text-align: center; margin-bottom: 2px; }
    .dace-a4-page .label { font-weight: bold; text-transform: uppercase; }
    .dace-a4-page .section { margin-top: 7px; padding-top: 5px; border-top: 1px solid #000; text-align: left; }
    .dace-a4-page .section-title { font-weight: bold; text-transform: uppercase; text-align: center; margin-bottom: 4px; font-size: 12.5px; }
    .dace-a4-page .section .line { margin-bottom: 2px; }
    .dace-a4-page .bottom    { width: 100%; border-collapse: collapse; margin-top: 9px; }
    .dace-a4-page .bottom td { vertical-align: top; padding: 0; }
    .dace-a4-page .qr-col   { width: 30%; text-align: center; padding-right: 7mm; }
    .dace-a4-page .qr-box   { text-align: center; }
    .dace-a4-page .qr-box img { width: 34mm; height: 34mm; max-width: 34mm; max-height: 34mm; }
    .dace-a4-page .legal-col { width: 70%; font-size: 10px; line-height: 1.28; text-align: justify; }
    .dace-a4-page .access-key-title { margin-top: 9px; text-align: center; font-weight: bold; font-size: 13px; }
    .dace-a4-page .access-key-value { text-align: center; font-weight: bold; font-size: 12px; line-height: 1.25; word-spacing: 2px; margin-top: 3px; }
    {% block extra_styles %}{% endblock %}
</style>

<div class="dace-a4-page">

    {% if dace.document.isHomologation %}
        <div class="notice">EMITIDA EM HOMOLOGAÇÃO</div>
    {% endif %}
    {% if dace.document.hasContingencyMessage %}
        <div class="notice">{{ dace.document.contingencyMessage }}</div>
    {% endif %}

    {% block logo %}{% endblock %}

    <div class="title">DACE RESUMIDA - DECLARAÇÃO AUXILIAR DE CONTEÚDO ELETRÔNICA</div>

    <div class="center-line">Nº {{ dace.document.numberFormatted }}&nbsp;&nbsp; SÉRIE {{ dace.document.series }}</div>
    <div class="center-line"><span class="label">DATA DE EMISSÃO:</span> {{ dace.document.issueDateTime }}</div>
    <div class="center-line">
        <span class="label">PROTOCOLO DE AUTORIZAÇÃO:</span>
        {{ dace.document.authorizationProtocol ?: '-' }}
        {% if dace.document.hasContingencyMessage %}({{ dace.document.contingencyMessage }}){% endif %}
    </div>
    <div class="center-line"><span class="label">MODALIDADE DO TRANSPORTE:</span> {{ dace.document.transportModeLabel }}</div>

    <div class="section">
        <div class="section-title">Remetente</div>
        <div class="line"><span class="label">CNPJ/CPF REMETENTE:</span> {{ dace.issuer.document ?: '-' }}</div>
        <div class="line"><span class="label">NOME REMETENTE:</span> {{ dace.issuer.name ?: '-' }}</div>
        <div class="line"><span class="label">CIDADE-UF REMETENTE:</span> {{ dace.issuer.cityUf ?: '-' }}</div>
        <div class="line"><span class="label">ENDEREÇO REMETENTE:</span> {{ dace.issuer.fullAddress ?: '-' }}</div>
    </div>

    <div class="section">
        <div class="section-title">Destinatário</div>
        <div class="line"><span class="label">CNPJ/CPF DESTINATÁRIO:</span> {{ dace.recipient.document ?: '-' }}</div>
        <div class="line"><span class="label">NOME DESTINATÁRIO:</span> {{ dace.recipient.name ?: '-' }}</div>
        <div class="line"><span class="label">CIDADE-UF DESTINATÁRIO:</span> {{ dace.recipient.cityUf ?: '-' }}</div>
        <div class="line"><span class="label">ENDEREÇO DESTINATÁRIO:</span> {{ dace.recipient.fullAddress ?: '-' }}</div>
    </div>

    <div class="section">
        <div class="section-title">Responsável</div>
        <div class="line">
            <span class="label">CNPJ FISCO / MARKETPLACE / TRANSPORTADOR:</span>
            {% if dace.hasResponsibleParty %}{{ dace.responsibleParty.document ?: '-' }}{% else %}-{% endif %}
        </div>
        <div class="line">
            <span class="label">NOME FISCO / MARKETPLACE / TRANSPORTADOR:</span>
            {% if dace.hasResponsibleParty %}{{ dace.responsibleParty.name ?: '-' }}{% else %}-{% endif %}
        </div>
    </div>

    <table class="bottom">
        <tr>
            <td class="qr-col">
                <div class="qr-box">
                    <img src="data:image/png;base64,{{ dace.assets.qrCodeImageBase64 }}" alt="QR-Code">
                </div>
            </td>
            <td class="legal-col">
                {% block legal_text %}{{ dace.additional.legalText|nl2br }}{% endblock %}
            </td>
        </tr>
    </table>

    <div class="access-key-title">Chave de Acesso DC-e</div>
    <div class="access-key-value">{{ dace.document.accessKeyFormatted }}</div>

    {% block footer %}{% endblock %}
</div>
