    "ext-dom": "*",
    "ext-libxml": "*",
    "ext-openssl": "*",
    "ext-soap": "*",
    "betocampoy/champs-certificate": "^1.0",
    "endroid/qr-code": "^6.0",
    "picqer/php-barcode-generator": "^3.2"
  },
  "autoload": {
    "psr-4": {
      "BetoCampoy\\Champs\\Fiscal\\": "src/"
    }
  },
  "authors": [
    {
      "name": "Beto Campoy"
    }
  ],
  "minimum-stability": "stable",
  "prefer-stable": true
