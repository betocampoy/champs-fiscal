{
  "name": "betocampoy/champs-fiscal",
  "description": "Componente fiscal reutilizável para DC-e (DACE) e NFS-e Nacional — emissão, consulta, cancelamento.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "fiscal",
    "dce",
    "dace",
    "nfse",
    "nfs-e",
    "nota-fiscal-servico",
    "soap",
    "certificate",
    "php"
  ],
  "require": {
    "php": ">=8.1",
    "ext-mbstring": "*",
    "ext-dom": "*",
    "ext-libxml": "*",
    "ext-openssl": "*",
    "ext-soap": "*",
    "betocampoy/champs-certificate": "^1.0",
    "endroid/qr-code": "^6.0",
    "picqer/php-barcode-generator": "^3.2",
    "symfony/http-client": "^6.4 || ^7.0"
  },
  "autoload": {
    "psr-4": {
      "BetoCampoy\\Champs\\Fiscal\\": "src/"
    }
  },
  "authors": [
    {
      "name": "Beto Campoy"
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true
}
